# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/
# 
# Steps:
# 1. Create a new project in Google Cloud Console
# 2. Enable the following APIs:
#    - Maps JavaScript API
#    - Directions API
#    - Geocoding API
# 3. Go to Credentials → Create Credentials → API Key
# 4. Copy your API key and paste it below
# 5. Rename this file to .env (remove .example)
# 6. Restart the development server

VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# GNews API Key for News Page
# Get your free API key from: https://gnews.io/
# 
# Steps:
# 1. Sign up at https://gnews.io/register
# 2. Verify your email
# 3. Copy your API key from the dashboard
# 4. Paste it below
# 
# Free tier: 100 requests/day
# The app will fallback to mock data if the API key is missing or limit is exceeded

VITE_GNEWS_API_KEY=YOUR_GNEWS_API_KEY_HERE
